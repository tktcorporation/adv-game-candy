// ============================================================
// Character definitions for 灯（あかり）
// ============================================================
//
// ★ このファイルがキャラクター設定の SSOT（Single Source of Truth）。
//
// 舞台: 定食屋「灯（あかり）」
//   駅から少し離れた路地の奥にある小さな定食屋。
//   カウンター8席、テーブル2つ。ランチは日替わり定食が一種類だけ。
//   看板が小さくて、知らないと通り過ぎる。
//   店主が一人で切り盛りしている。常連が多い。静かで居心地がいい。
//
// 物語の構造:
//   主人公とヒロインは同じ定食屋の常連客。
//   2人とも「客」という対等な立場から、定食屋という空間を通じて
//   徐々に距離を縮めていく。店主がその触媒になる。
//
// === 年齢方針 ===
// 全キャラ年齢非公開。プレイヤーの想像に委ねる。
// age フィールドは 0 を入れ、コメントでイメージだけ示す。
//
// === キャラクター導入順序 ===
// ch0:  椎名ひより（同じ店の常連・ヒロイン）
// ※ サブキャラは今後の章で追加予定
//
// === 天丼フレーズ（繰り返し技法） ===
// 物語全体を通じて反復され、変化が感情的カタルシスを生む。
//
//   ひよりの「……ごちそうさまでした」:
//     ch0〜全編で反復。去り際の儀式。声の大きさ・タイミングの微細な変化で
//     ひよりの内面を暗示する。最初は店主にだけ向けた言葉。
//     終盤で主人公に向けて言う瞬間がカタルシス。
//
//   文庫本のページがめくれない:
//     ひよりが感情を揺さぶられた時の無意識の反応。
//     ch0で初出（椅子を直す場面）。ch1で反復（譲ってくれたことに気づく場面）。
//     同じ描写の反復で「この人はまた動揺している」と読者に伝わる。
//
//   席の距離:
//     カウンターの端と端 → 少し近く → 二つ空け → 隣
//     物理的距離＝心理的距離。言葉よりも席の位置が関係を語る。
//
//   主人公の無自覚の善意:
//     ch0: 椅子を直す。ch1: 日替わりを譲る。
//     「誰かのため」ではなく「なんとなく」。でもひよりだけが気づく。
//     このパターンの反復が、ひよりの変化の原動力になる。
//
// === ひよりの「席×言葉」推移 ===
// 席の位置が近くなるにつれ、交わす言葉も変わっていく。
//
//   序盤:   カウンターの反対側。「日替わりで」「ごちそうさま」のみ
//   前中盤: 二つ空けた席。醤油差しの受け渡し。「……ありがとうございます」
//   中盤:   一つ空けた席。天気の話、小鉢の感想。短い会話
//   後半:   隣の席。名前を呼び合う。食べ物の好みを知っている
//   転:     来なくなる、または反対側に戻る（すれ違い）
//   結:     隣の席が定位置に。「……美味しいね」
//
// === 主人公: 高瀬 晴（たかせ はる） ===
// Character 構造体には入らないが、全シナリオの主語であり最も重要な設定。
// シナリオ内の speaker は「主人公」。ゲーム中はプレイヤー入力名で表示。
//
//   名前: 高瀬 晴（デフォルト）。プレイヤーが変更可能
//   一人称: 俺
//   年齢イメージ: 20代前半
//
//   ---- 背景 ----
//   この町に引っ越してきて1ヶ月くらい。
//   就職はしたが、配属先が合わず半年で辞めた。
//   今は派遣で事務仕事をしながら、次にやりたいことを探している。
//   一人暮らし。自炊は面倒で、外食が多い。
//   「灯」を見つけたのは引っ越して二週間目。
//   路地の奥で「定食」ののぼりを見つけて、ふらっと入った。
//   それから、ほぼ毎日。味がいいし、量もちょうどいいし、静か。
//
//   ---- 性格の核 ----
//   明るいツッコミ型。会話のテンポがいい。
//   でも根っこは受動的。自分から動くのが苦手。
//   他者への気配りは無意識にやる（椅子を直す、食事を譲る）が、
//   自分がそういう人間だとは思っていない。
//   自己評価が低いわけではないが、期待値が低い。
//   「まあ、こんなもんだろ」が口癖。
//
//   ---- Want / Need ----
//   Want: 特にない。「とりあえず毎日を過ごしている」。
//     → ひよりの存在に気づいて「あの人のこと、もっと知りたい」に変わる。
//   Need: 自分から何かを選ぶこと。
//     流されて今の生活をしているが、最終的に「ここにいたい」と自分で決める。
//
//   ---- 外見 ----
//   特徴が薄い。「普通の男」。身長は中くらい。
//   髪は黒でやや長め。手入れはしていないが不潔ではない。
//   私服はシンプル。パーカーかシャツにジーンズ。
//
//   ---- 声・話し方 ----
//   低めだが柔らかい声。ぼそっと話す。
//   ツッコミは鋭いが声を荒げない。淡々と返す。
//   内心のモノローグは少し饒舌（読者だけが聞ける本音）。
//
// === 店主: 丸山 信一（まるやま しんいち） ===
// speaking role を持つ。シナリオ内の speaker は「店主」。
//
//   年齢イメージ: 50代後半。
//
//   ---- 背景 ----
//   「灯」を20年以上一人で営んでいる。
//   妻を10年前に亡くし、店が生きがい。
//   仕込みは朝4時から。日替わり定食は一種類だけ。
//   「一つのものを丁寧に作る」がポリシー。
//   常連の顔は全部覚えている。名前は聞かない。自然に覚える。
//
//   ---- 性格の核 ----
//   おしゃべり。黙っていられない。常連との会話が楽しい。
//   無意識に人の情報を漏らす（悪気はない）。
//     → 「あの子がカレーにしてくれたからねえ」でひよりが気づくのはこのため。
//   ただし、人の心の機微には鈍い。
//   気遣いは「福神漬けを多めにする」のような行動で示すタイプ。
//
//   ---- 外見 ----
//   がっしりした体格。白い調理服にバンダナ。
//   手が大きくて、指先に小さな火傷の跡がいくつもある。
//   笑うと目が細くなる。
//
//   ---- 声・話し方 ----
//   よく通る声。「〜だよ」「〜なんだけどね」。語尾が柔らかい。
//   客に話しかけるのが好き。一人で喋っていることもある。
//   「いいよねえ」「美味しくできたんだよねえ」が口癖。
//
// ============================================================

/// Get all characters
/// 定食屋「灯」の常連客とサブキャラクター。
/// 主人公（高瀬晴）と店主（丸山信一）はコメントで定義し、
/// Character 構造体にはヒロインとサブキャラを格納する。
pub fn get_characters() -> Array[Character] {
  [
    {
      id: "shiina",
      name: "椎名 ひより",
      age: 0, // 明示しない。20代前半のイメージ
      background: "主人公と同じ定食屋「灯」の常連。引っ越してくる前からこの店に通っている。近所の図書館で司書をしている。本が好き。人見知りだが、慣れた相手には意外とちゃんと話す。最初は定食屋の居心地の良さで通っていたが、主人公が来るようになってから、少しだけ来る時間を気にするようになった。本人はそれに気づいていない。",
      appearance: "腰まである長い黒髪をそのまま下ろしている。前髪は目にかかるかかからないかの長さ。細身で少し小柄。落ち着いた色の服が多い——紺か白かベージュ。カーディガンを羽織っていることが多い。鞄はトートバッグで、必ず文庫本が1冊入っている。冬はマフラーに顔を半分埋める。",
      mannerisms: "本を読むとき左手の人差し指でページの端を軽く押さえる。定食が来るまで文庫本を読んでいる。注文はいつも「日替わりで」。声は小さいけど、はっきりしている。食べる前に小さく手を合わせる。帰る時に必ず「ごちそうさまでした」と言う。席は序盤はカウンターの反対側の端→徐々に主人公の方に近づいていく。",
      expression: "基本的にあまり表情が動かない。でも「無表情」ではなく「穏やか」。本を読んでいる時が一番リラックスした顔をしている。驚くとほんの少し目を見開くだけ。笑う時は口元がわずかに緩む程度——声を出して笑うことはほとんどない。主人公の方をチラッと見ることがあるが、目が合うと本に視線を戻す。",
      voice: "静かで落ち着いた声。言葉数が少なく、一文が短い。「……」から始まることが多い。敬語ベース。感想を求められると「……美味しかったです」と短く返す。感情が動いた時ほど言葉が少なくなる——本当に嬉しい時は何も言えない。",
      pattern: "ほぼ毎日。昼。同じ時間帯に来る",
      favorite_menu: "d_daily", // 日替わり定食
      challenge_menu: "d_curry", // カレー（普段は頼まない）
      intro_chapter: 0,
    },
  ]
}

/// 親密度レベルの説明テキスト（マイルストーン用）
///
/// 旧★システム(1-5)を廃止し、上限なしの親密度レベルに移行。
/// 特定レベルで関係性の質的変化を表現する。
pub fn get_affection_description(level : Int) -> String {
  if level < 3 {
    "同じ店の客。顔は知ってるが話したことはない。"
  } else if level < 5 {
    "醤油差しを渡す程度の関係。声を聞いたことがある。"
  } else if level < 10 {
    "名前を知っている。天気の話くらいはする。"
  } else if level < 15 {
    "隣に座っても気まずくない。好きな小鉢を知っている。"
  } else if level < 20 {
    "この席が、二人の場所になった。"
  } else if level < 30 {
    "言葉がなくても、隣にいるだけで落ち着く。"
  } else if level < 50 {
    "灯を出た後も、ふと相手のことを思い出す。"
  } else if level < 70 {
    "いつからか、灯に来る理由が変わっていた。"
  } else if level < 100 {
    "灯にいる時間が、一日で一番穏やかだ。"
  } else {
    "言葉にしなくても、伝わっている気がする。"
  }
}

/// 親密度マイルストーン報酬テーブル
///
/// 親密度レベル到達時の報酬。5レベルごとにジェム、10レベルごとに大報酬。
/// 上限なしのため、高レベルでも報酬が続く。
pub fn get_affection_milestones() -> Array[AffectionMilestone] {
  [
    { level: 3, reward_type: "gem", reward_amount: 20, description: "20 星石" },
    { level: 5, reward_type: "gem", reward_amount: 50, description: "50 星石" },
    { level: 8, reward_type: "gem", reward_amount: 30, description: "30 星石" },
    { level: 10, reward_type: "gem", reward_amount: 100, description: "100 星石 + ボンドストーリー" },
    { level: 13, reward_type: "gem", reward_amount: 30, description: "30 星石" },
    { level: 15, reward_type: "gem", reward_amount: 50, description: "50 星石" },
    { level: 18, reward_type: "gem", reward_amount: 30, description: "30 星石" },
    { level: 20, reward_type: "gem", reward_amount: 100, description: "100 星石 + ボンドストーリー" },
    { level: 25, reward_type: "gem", reward_amount: 80, description: "80 星石" },
    { level: 30, reward_type: "gem", reward_amount: 120, description: "120 星石 + ボンドストーリー" },
    { level: 40, reward_type: "gem", reward_amount: 150, description: "150 星石 + ボンドストーリー" },
    { level: 50, reward_type: "gem", reward_amount: 200, description: "200 星石 + ボンドストーリー" },
    { level: 60, reward_type: "gem", reward_amount: 200, description: "200 星石" },
    { level: 70, reward_type: "gem", reward_amount: 200, description: "200 星石 + ボンドストーリー" },
    { level: 80, reward_type: "gem", reward_amount: 250, description: "250 星石" },
    { level: 100, reward_type: "gem", reward_amount: 300, description: "300 星石 + ボンドストーリー" },
  ]
}

/// カードプレイ後のひよりのリアクションテキスト
///
/// 行動タイプ × 親密度レベルのマトリクスで、短い1行リアクションを返す。
/// 親密度が上がるほどリアクションが豊かになる。上限なし対応（Lv50+にもテキストあり）。
///
/// Scene画面で「♪ ひよりが少しこちらを見た」のように表示する。
/// 呼び出し元: logic.mbt の play_card() → state.last_card_result に格納
pub fn get_reaction_text(action_type : String, affection_level : Int) -> String {
  match action_type {
    "eat" =>
      if affection_level < 3 {
        ""
      } else if affection_level < 10 {
        "箸の動きが揃った。"
      } else if affection_level < 20 {
        "「……美味しいですね」"
      } else if affection_level < 30 {
        "二人分のいただきます。"
      } else if affection_level < 50 {
        "自然に小鉢を分けた。"
      } else {
        "「今日も一緒ですね」"
      }
    "observe" =>
      if affection_level < 3 {
        "本に集中している。"
      } else if affection_level < 10 {
        "ちらりとこちらを見た。"
      } else if affection_level < 20 {
        "視線が合って微笑んだ。"
      } else if affection_level < 30 {
        "「……見すぎですよ」"
      } else if affection_level < 50 {
        "読んでる本を見せてくれた。"
      } else {
        "肩が触れても離れない。"
      }
    "talk" =>
      if affection_level < 3 {
        "丸山が間に入ってくれた。"
      } else if affection_level < 10 {
        "小さく頷いた��"
      } else if affection_level < 20 {
        "自分から話し始めた。"
      } else if affection_level < 30 {
        "穏やかに笑っている。"
      } else if affection_level < 50 {
        "声を出して笑った。"
      } else {
        "「……ずっと、こうしていたい」"
      }
    _ => ""
  }
}

