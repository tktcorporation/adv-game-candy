// Character definitions for 月灯り（ラブコメ版）
//
// 各キャラクターの設定資料。appearance / mannerisms / expression / voice は
// シナリオ執筆時の描写一貫性と、将来の立ち絵・キャラ図鑑UIのために保持。
// シナリオ内で人物を描く際は必ずこの設定を参照すること。
//
// 重要: character-appeal スキルに従い、全キャラの言動が読者に愛されるか確認すること。
// 特に佐倉は「言葉×距離」ギャップの設計に従う。

/// Get all characters
pub fn get_characters() -> Array[Character] {
  [
    {
      id: "sakura",
      name: "佐倉 美月",
      age: 0, // 明示しない。20代前半のイメージ
      background: "おばさんの時代からの常連。コーヒーに詳しい（実家がコーヒー好き）。クールに見えるが猫の前でボロが出る。",
      appearance: "肩にかかるくらいの栗色の髪を、ゆるくひとつに結んでいる。前髪は目にかからない程度。華奢で少し猫背気味。白いブラウスかニットにスカート、落ち着いた色の服が多い。文庫本がいつも鞄に入っている。冬はマフラーに顔を半分埋める。",
      mannerisms: "本を読むとき左手の人差し指でページの端を軽く押さえる。考え事をするとカップの縁を指先でなぞる。驚いても大きなリアクションを取らず、ほんの少し目を見開くだけ。帰る時に小さく「ごちそうさま」と言う。席は序盤は窓際→中盤でカウンター寄りに移動してくる（本人は理由をつける）。",
      expression: "基本的に無表情に近い。本越しにこちらを見る時だけ少し目が柔らかくなるが、気づかれると逸らす。笑う時は口元だけ——声を出して笑うことはほとんどない。不満がある時は本のページをめくる速度が上がる。主人公の方をチラチラ見ているが本人はバレてないと思っている。",
      voice: "低めの落ち着いた声。言葉数が少なく、一文が短い。「……」から始まることが多い。敬語は使わないが丁寧。感想を求められると「……普通」「……別に」。たまにぽつりとコーヒーのアドバイスが漏れる。",
      pattern: "ほぼ毎日。午後。雨でも来る",
      favorite_menu: "r_blend",
      challenge_menu: "r_latte",
      intro_chapter: 0,
    },
    {
      id: "amano",
      name: "天野 蓮",
      age: 0, // 明示しない。主人公より少し下
      background: "バイト。口が悪くて元気。佐倉と主人公の関係をいじる担当。面倒見は実はいい。",
      appearance: "ショートボブの黒髪。活発な印象で、よく動く。パーカーにショートパンツかジーンズ、スニーカーが定番。リュックは片方の肩にだけかけている。左手首にカラフルなヘアゴムを何本もつけている（ヘアゴム忘れた人にあげる用、と本人は言う）。小柄。",
      mannerisms: "話す時に手が動く。リュックの肩紐を無意識に引っ張る癖。ココアを飲む時はカップを両手で包む。主人公を「店長」と呼ぶ。佐倉のことを「佐倉さん」と呼ぶが、からかう時は「佐倉先輩」。",
      expression: "基本的にいつもニヤニヤしている。主人公と佐倉のやりとりを見る時は特に。本当に嬉しい時は目が丸くなる。困った時は頭の後ろに手をやる。たまに真面目な顔をすると周囲が驚く。",
      voice: "明るく少し高めの声。早口で「っす」語尾が特徴。一人称「あたし」。感嘆詞が多い（マジ、うわ、えー）。佐倉と主人公の関係を「またやってんじゃん」的にツッコむ。本音を話す時だけテンポが落ちる。",
      pattern: "バイトのシフト日。週4-5",
      favorite_menu: "r_cocoa",
      challenge_menu: "r_caramel_latte",
      intro_chapter: 1,
    },
    {
      id: "kanzaki",
      name: "神崎 凛",
      age: 0, // 明示しない。主人公より少し上
      background: "フリーライター。Wi-Fiとコンセント目当てでカフェに来る。観察力が鋭く、佐倉の気持ちに最初に気づく。恋愛には「見守る側」。",
      appearance: "ショートカットの黒髪。耳が見えるくらい短い。小柄だが姿勢がよく、動きにキレがある。リップだけはいつも赤い。ノートPCとスマホが常にテーブルに並んでいる。カジュアルだがどこかおしゃれ。革ジャンかオーバーサイズのシャツにデニム。",
      mannerisms: "人の話を聞く時、ペンをノックする癖。主人公と佐倉のやりとりを見てニヤニヤする。コーヒーを飲む時は片手で、もう片方はキーボードに添えている。何か面白いことを発見すると「へえ」と声に出る。",
      expression: "基本的にクールで、口角がやや上がった面白がりの表情がデフォルト。佐倉と主人公の空気を読んで楽しんでいる。本当に面白い時は子供みたいに目が輝く。主人公が鈍感なことをすると呆れ顔。",
      voice: "はっきりした声。歯切れがよく、語尾を伸ばさない。「〜じゃない？」「〜でしょ」。褒める時は「悪くないね」。佐倉に対して「佐倉ちゃん」。主人公に「あんた」。ストレートにものを言う。",
      pattern: "不定期。Wi-Fiが必要な時",
      favorite_menu: "r_espresso",
      challenge_menu: "r_seasonal_blend",
      intro_chapter: 4,
    },
    {
      id: "kiritani",
      name: "桐谷 楓",
      age: 0, // 明示しない
      background: "隣にできたチェーン店「Café BLANC」のスタッフ。有能で礼儀正しいが天然。競合なのに差し入れを持ってくる。佐倉が微妙にピリつく存在。",
      appearance: "セミロングの茶髪をきちんとまとめたポニーテール。チェーン店の制服（白シャツにエプロン）が多いが、私服はふわっとしたワンピースが多い。化粧は薄いが眉だけきっちり。笑顔が自然で感じがいい。",
      mannerisms: "コーヒーを飲む前に必ず香りを嗅ぐ。座る時にスカートの裾を軽く押さえる。天然ボケをかます時に自分で気づいていない。差し入れを持ってくる時に「これ余っちゃって」と言うが、明らかにわざわざ持ってきている。",
      expression: "営業用ではない、本当に柔らかい笑顔がデフォルト。困った時に首を傾げる。佐倉にピリつかれている時に気づかないふりをしている（実は少し気づいている）。",
      voice: "丁寧語が基本だが硬くない。「〜ですよね」「〜かもしれないですけど」。ふとした時に「あ」から始まる素の声が漏れる。主人公を「店長さん」と呼ぶ。",
      pattern: "不定期。差し入れの時",
      favorite_menu: "r_vanilla_latte",
      challenge_menu: "r_blend",
      intro_chapter: 9,
    },
  ]
}

/// Get intimacy ranks
pub fn get_intimacy_ranks() -> Array[IntimacyRank] {
  [
    { stars: 1, min_points: 0, description: "初対面。表面的なやりとり。" },
    { stars: 2, min_points: 100, description: "名前を覚えてもらえた。好みが分かる。" },
    { stars: 3, min_points: 300, description: "サイドエピソード解放。特別な頼みごと。" },
    { stars: 4, min_points: 600, description: "深い話ができる。特別なスキル。" },
    { stars: 5, min_points: 1000, description: "最終エピソード。エンディングに影響。" },
  ]
}

