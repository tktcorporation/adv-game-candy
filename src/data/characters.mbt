// Character definitions for 廃墟カフェ復興記
//
// 各キャラクターの設定資料。appearance / mannerisms / expression / voice は
// シナリオ執筆時の描写一貫性と、将来の立ち絵・キャラ図鑑UIのために保持。
// シナリオ内で人物を描く際は必ずこの設定を参照すること。

/// Get all characters
pub fn get_characters() -> Array[Character] {
  [
    {
      id: "sakura",
      name: "佐倉 美月",
      age: 32,
      background: "元パティシエ。3年前に自分の店を閉めた。",
      appearance: "肩にかかるくらいの栗色の髪を、ゆるくひとつに結んでいる。前髪は目にかからない程度。華奢だが手指は職人のそれ——爪は短く、薄い火傷の痕がいくつか。白いブラウスにリネンのワイドパンツ、落ち着いたアースカラーの服が多い。冬はベージュのストールを肩にかける。文庫本がいつも鞄に入っている。",
      mannerisms: "本を読むとき左手の人差し指でページの端を軽く押さえる。考え事をするとカップの縁を指先でなぞる。驚いても大きなリアクションを取らず、ほんの少し目を見開くだけ。立ち去る時に小さく会釈する癖がある。",
      expression: "基本的に穏やかだが感情を表に出さない。本越しにこちらを見る時だけ、少し目が柔らかくなる。笑う時は口元だけ——声を出して笑うことはほとんどない。怒りは表さないが、不満がある時は本のページをめくる速度が上がる。",
      voice: "低めの落ち着いた声。言葉数が少なく、一文が短い。「……」から始まることが多い。敬語は使わないが丁寧。相手の名前を呼ぶことが少ない。",
      pattern: "平日の午後、ほぼ毎日",
      favorite_menu: "r_deep_blend",
      challenge_menu: "r_houjicha_latte",
      intro_chapter: 0,
    },
    {
      id: "amano",
      name: "天野 蓮",
      age: 19,
      background: "大学生。経営学部。実家の金物屋は去年閉店。",
      appearance: "少し長めの黒髪で、前髪がよく目にかかる。痩せ型で背が高い。パーカーにジーンズ、スニーカーが定番。リュックは片方の肩にだけかけている。左手首に安っぽいミサンガを巻いている——実家の金物屋最終日に妹が作ってくれたもの。",
      mannerisms: "話す時に手が動く。リュックの肩紐を無意識に引っ張る癖。ココアを飲む時はカップを両手で包む。考え込むと前髪を掻き上げるが、すぐ戻る。レポートを書く時はペンをくるくる回す。",
      expression: "基本的にいつも笑顔。目を細めてにかっと笑う。でもふとした瞬間——特に商店街の話題が出ると、一瞬だけ笑顔が固まる。本当に嬉しい時は目が丸くなる。困った時は頭の後ろに手をやる。",
      voice: "明るく少し高めの声。早口で「っす」語尾が特徴。感嘆詞が多い（マジ、うわ、えー）。本音を話す時だけ急にテンポが落ちて、敬語が混じる。",
      pattern: "夕方〜夜、週3-4回",
      favorite_menu: "r_cocoa",
      challenge_menu: "r_caramel_latte",
      intro_chapter: 1,
    },
    {
      id: "miyauchi",
      name: "宮内 孝之",
      age: 58,
      background: "古書店「栞堂」店主。前オーナーの旧友。",
      appearance: "白髪交じりの短髪、きちんと整えられている。細身だが背筋がまっすぐで、座っている時も姿勢が崩れない。丸い銀縁眼鏡をかけている。カーディガンにシャツ、スラックス。服の色は紺やチャコールグレーが多い。指が長く、古書を扱い慣れた手。左手の薬指に古い銀の指輪。",
      mannerisms: "湯呑みを両手で包むように持つ。眼鏡を外して拭く仕草が考え事のサイン。話す前に一拍置く——言葉を選んでいるのが分かる。立ち上がる時に膝に手を当てるが、動作自体は静かで品がある。",
      expression: "目が鋭く、初対面は威圧感がある。しかし口元に皺が刻まれていて、かつてよく笑っていた顔だと分かる。感情を見せる時は目を閉じる——味わうように。前のオーナーの話をする時だけ、視線が窓の外の遠くに向かう。",
      voice: "低く落ち着いた声。「〜だな」「〜だろう」という断定的な語尾。だが命令口調ではなく、独り言のような響き。「わし」と言うことがある。沈黙を恐れない——むしろ沈黙を会話の一部にする人。",
      pattern: "週末の朝",
      favorite_menu: "r_houjicha",
      challenge_menu: "r_houjicha_latte",
      intro_chapter: 2,
    },
    {
      id: "kanzaki",
      name: "神崎 凛",
      age: 28,
      background: "地元紙の記者。元大手出版社。",
      appearance: "ショートカットの黒髪。耳が見えるくらい短く、後ろは刈り上げに近い。小柄だが姿勢がよく、動きにキレがある。ノーメイクに近いがリップだけはいつも赤い。カメラバッグを右肩にかけ、手帳とボールペンが常にジーンズの後ろポケットに刺さっている。革のジャケットかシャツにデニム。靴はいつもフラットシューズ——すぐ走れるように。",
      mannerisms: "人の話を聞く時、ボールペンをノックする癖。目を細めて相手を見る——品定めするような、でも興味があるからこその視線。メモを取る手が速い。コーヒーを飲む時は片手で、もう片方は必ず手帳に添えている。店を出る時に振り返って一言残す癖がある。",
      expression: "基本的にクールで、口角がやや上がった皮肉っぽい表情がデフォルト。でも本当に面白いものを見つけた時は、子供みたいに目が輝く——そしてすぐに取り繕う。怒る時は声が低くなるのではなく、逆に静かに笑う。",
      voice: "はっきりした声。歯切れがよく、語尾を伸ばさない。「〜じゃない」「〜でしょう」といった断定的な女性語。褒める時は「嫌いじゃないわ」——直接褒めない。東京時代の癖で、ときどき標準語のイントネーションが混じる。",
      pattern: "不定期、取材の合間",
      favorite_menu: "r_seasonal_blend",
      challenge_menu: "r_apple_cinnamon",
      intro_chapter: 3,
    },
    {
      id: "kiritani",
      name: "桐谷 楓",
      age: 26,
      background: "Café BLANCエリアマネージャー。",
      appearance: "セミロングの茶髪をきちんとまとめたハーフアップ。スーツ姿が多く、ブラウスはいつもアイロンがかかっている。華奢に見えるが背筋がしっかりしていて、ヒールでの歩き方が美しい。名刺入れは革製で使い込まれている。薄い化粧だが眉だけはきっちり描いている——隙のなさの象徴。アクセサリーは小ぶりのピアスひとつだけ。",
      mannerisms: "名刺を差し出す所作が洗練されている。コーヒーを飲む前に必ず色を確かめ、次に香りを嗅ぐ——評価のプロトコル。座る時にスカートの裾を軽く押さえる。笑顔の後にさりげなく時計を確認する。メモは取らない——全て頭に入れるタイプ。",
      expression: "営業用の柔らかい笑顔がデフォルト。でもコーヒーを味わっている瞬間だけ、仕事の顔が消えて素の表情になる。相手を見る時は少し首を傾ける——聞いています、のサイン。本気で感心した時は唇を薄く開けて「へえ」と声を漏らす。",
      voice: "丁寧語が基本で崩さない。声は柔らかいが芯がある。「〜いたします」「〜でございます」のビジネス敬語を自然に使う。でもふとした瞬間に「あ、美味しい」のような素の声が漏れる——そこに本音がある。",
      pattern: "不定期",
      favorite_menu: "r_vanilla_coffee",
      challenge_menu: "r_tsukiakari",
      intro_chapter: 4,
    },
  ]
}

/// Get intimacy ranks
pub fn get_intimacy_ranks() -> Array[IntimacyRank] {
  [
    { stars: 1, min_points: 0, description: "初対面。表面的なやりとり。" },
    { stars: 2, min_points: 100, description: "名前を覚えてもらえた。好みが分かる。" },
    { stars: 3, min_points: 300, description: "サイドエピソード解放。特別な頼みごと。" },
    { stars: 4, min_points: 600, description: "深い話ができる。特別なスキル。" },
    { stars: 5, min_points: 1000, description: "最終エピソード。エンディングに影響。" },
  ]
}

