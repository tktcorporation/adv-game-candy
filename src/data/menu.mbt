// 日替わりメニュー＆行動テキスト — 定食屋「灯」
//
// 日数のハッシュ（day % length）で決定的に選ばれる。
// 同じ日に何度アクセスしても同じメニュー・テキストが表示される。

/// 全日替わりメニュー定義
///
/// intimacy_bonus はメニューの「特別感」で差をつけている。
/// 数量限定や得意メニューは高め（12）、シンプルなものは低め（8-9）。
pub fn get_daily_menus() -> Array[DailyMenu] {
  [
    { id: "d_saba_miso", name: "鯖の味噌煮定食", description: "脂ののった鯖に、白味噌の甘さ", intimacy_bonus: 10 },
    { id: "d_nikujaga", name: "肉じゃが定食", description: "じゃがいもがほくほく。家庭の味", intimacy_bonus: 10 },
    { id: "d_hamburg", name: "煮込みハンバーグ定食", description: "デミグラスソースでじっくり。数量限定", intimacy_bonus: 12 },
    { id: "d_karaage", name: "鶏の唐揚げ定食", description: "カリッと揚がった大ぶりの唐揚げ", intimacy_bonus: 10 },
    { id: "d_kakuni", name: "豚の角煮定食", description: "とろとろに煮込んだ三枚肉", intimacy_bonus: 11 },
    { id: "d_saba_shio", name: "鯖の塩焼き定食", description: "シンプルに塩で。皮がパリッと", intimacy_bonus: 9 },
    { id: "d_teriyaki", name: "鶏の照り焼き定食", description: "甘辛いタレが絡んで、ご飯が進む", intimacy_bonus: 11 },
    { id: "d_curry", name: "カレー", description: "灯の隠れた定番。スパイスが優しい", intimacy_bonus: 8 },
    { id: "d_shogayaki", name: "豚の生姜焼き定食", description: "生姜の香りが食欲をそそる", intimacy_bonus: 10 },
    { id: "d_oyakodon", name: "親子丼", description: "卵がふわとろ。丸山の得意メニュー", intimacy_bonus: 12 },
    { id: "d_sanma", name: "秋刀魚の塩焼き定食", description: "秋の味覚。大根おろしを添えて", intimacy_bonus: 11 },
    { id: "d_butaniku", name: "豚汁定食", description: "具だくさんの豚汁がメイン。冬の定番", intimacy_bonus: 10 },
  ]
}

/// 今日の日替わりメニューを取得
///
/// day % menus.length() で決定的に選択。同じ日なら必ず同じメニュー。
pub fn get_today_menu(day : Int) -> DailyMenu {
  let menus = get_daily_menus()
  menus[day % menus.length()]
}

// =========================================================================
// 行動テキスト — 行動タイプ × 親密度段階 × 日数ハッシュ
// =========================================================================

/// 「食べる」行動のシーンテキスト
///
/// 親密度段階(4段階) × バリエーション(4種) = 16テキスト。
/// 食事シーンを中心に、ひよりとの距離感の変化を描く。
fn get_eat_texts(intimacy : Int) -> Array[String] {
  if intimacy < 100 {
    [
      "カウンターの反対側で、彼女も同じものを食べている。",
      "向こう側でも、箸が動いている。同じ店、同じ時間。それだけの関係。",
      "いつもの席。いつもの定食。向こう側に、いつもの人。",
      "黙々と食べる。隣の席には誰もいない。反対側に、あの人がいる。",
    ]
  } else if intimacy < 300 {
    [
      "二つ向こうの席から、小さな「いただきます」が聞こえた。",
      "ちらっと視線が合った気がした。気のせいかもしれない。",
      "隣の席との間に、醤油差しが一つ。距離はまだ遠い。",
      "箸の音だけが、静かに響いている。……今日も来てるな。",
    ]
  } else if intimacy < 600 {
    [
      "「今日の、美味しいですね」。一つ空けた席から、小さな声。",
      "隣から味噌汁の匂い。同じものを食べている安心感。",
      "同じタイミングで箸が止まった。目が合って、少しだけ笑った。",
      "「……おかわり、しますか？」。お茶のやかんを差し出された。",
    ]
  } else {
    [
      "「今日は何だろう」。隣に座ったひよりが、少し楽しそうに言った。",
      "二人分の「いただきます」が重なった。丸山がニヤニヤしている。",
      "「好きなんですか？」「うん、ここのは全部好き」",
      "隣の席が、いつの間にか「いつもの席」になっていた。",
    ]
  }
}

/// 「観察する」行動のシーンテキスト
///
/// 店内の様子やひよりの小さな仕草を観察する。
/// 発見テキストとは別に、シーン描写を返す。
fn get_observe_texts(intimacy : Int) -> Array[String] {
  if intimacy < 100 {
    [
      "店内を見回す。壁に貼られたメニュー表。年季の入ったカウンター。",
      "窓から差し込む光が、カウンターの木目を照らしている。",
      "向こうの席の人が、本を読んでいる。食べ終わっても帰らないんだな。",
      "丸山が包丁を研いでいる。リズミカルな音が心地いい。",
    ]
  } else if intimacy < 300 {
    [
      "あの人、今日は文庫本じゃなくてハードカバーだ。",
      "壁の写真に気づいた。若い頃の丸山と、知らない人が写っている。",
      "ひよりが読んでいる本の表紙がちらっと見えた。",
      "湯気の向こうに、ページをめくる指が見える。",
    ]
  } else if intimacy < 600 {
    [
      "ひよりの読んでいる本、前にも見たことがある気がする。",
      "丸山が小鉢を一品サービスしてくれた。常連の特権らしい。",
      "ひよりが食後にお茶を飲む姿。少し目を細めている。",
      "カウンターの端に、誰かが忘れた栞が置いてある。",
    ]
  } else {
    [
      "ひよりが本を閉じて、ぼんやり外を見ている。珍しい。",
      "丸山が二人分のお茶を、何も言わずに出してくれた。",
      "隣の席に、ひよりの本が置いてある。いつの間にか自然なことになった。",
      "窓の外、桜が散り始めている。来年もここに来ているだろうか。",
    ]
  }
}

/// 「丸山と話す」行動のシーンテキスト
///
/// 店主との会話。ひよりの情報が漏れることも。
fn get_talk_texts(intimacy : Int) -> Array[String] {
  if intimacy < 100 {
    [
      "丸山 「お、今日も来たね。毎日偉いねえ」",
      "丸山 「この店もう三十年やってんのよ。信じられる？」",
      "丸山 「最近の若い人はみんなスマホ見てるけど、あんたは違うね」",
      "丸山 「今日の仕込み、ちょっと味噌の配合変えてみたんだけど、わかった？」",
    ]
  } else if intimacy < 300 {
    [
      "丸山 「あの子、毎日同じ時間に来るんだよ。あんたと同じでね」",
      "丸山 「あの子、いつも本読んでるだろ。すごい集中力だよな」",
      "丸山 「昔はもっと客が多かったんだけどね。今はこのくらいがちょうどいい」",
      "丸山 「あの子、漬物だけは残すんだよ。苦手なんだろうね」",
    ]
  } else if intimacy < 600 {
    [
      "丸山 「最近、あの子の表情が柔らかくなった気がするんだよね」",
      "丸山 「あの子、椎名さんっていうんだ。知ってた？」",
      "丸山 「俺が言うのもなんだけど、あんたが来る日はあの子も楽しそうだよ」",
      "丸山 「あの子、親子丼が好きなんだよ。卵ふわふわのやつ」",
    ]
  } else {
    [
      "丸山 「二人ともすっかり常連だねえ。最初の頃を思い出すよ」",
      "丸山 「あんたたち、いつの間にか隣に座るようになったね」",
      "丸山 「まあ、俺は見てるだけだからさ。邪魔はしないよ」",
      "丸山 「今度、あの子の好きなメニュー多めに仕込んどくよ」",
    ]
  }
}

/// 「特別行動」のシーンテキスト（★3以降で解放）
///
/// より踏み込んだ関係性の行動。本を薦める、席を選ぶなど。
fn get_special_texts(intimacy : Int) -> Array[String] {
  if intimacy < 600 {
    [
      "ひよりの隣の席に、思い切って座ってみた。少し緊張する。",
      "「……この本、面白いですか？」。思い切って聞いてみた。",
      "ひよりの分のお茶も一緒に頼んでみた。丸山が嬉しそうだ。",
      "「今日のおすすめ、美味しかったですね」。自然に話しかけられた。",
    ]
  } else {
    [
      "「この本、読み終わったんで……よかったら」。ひよりが少し驚いた顔をした。",
      "いつもの席に二人で並んで座る。丸山が黙ってお茶を二つ出した。",
      "「明日も来ますか？」「……うん」。小さな約束。",
      "帰り際、ひよりが「ごちそうさまでした」の後に、「また明日」と言った。",
    ]
  }
}

/// 行動テキストを取得する
///
/// action_type × 親密度段階 × day のハッシュでバリエーションを選択。
/// logic.mbt の perform_action から呼ばれる。
pub fn get_action_text(action_type : String, intimacy : Int, day : Int) -> String {
  let texts : Array[String] = if action_type == "eat" {
    get_eat_texts(intimacy)
  } else if action_type == "observe" {
    get_observe_texts(intimacy)
  } else if action_type == "talk" {
    get_talk_texts(intimacy)
  } else {
    get_special_texts(intimacy)
  }
  texts[day % texts.length()]
}

// =========================================================================
// コレクション用テキスト（アルバムに蓄積される）
// =========================================================================

/// 「観察する」で得られる発見テキスト
///
/// アルバムの「発見ノート」に蓄積される。ひよりや店の情報。
pub fn get_discovery_text(intimacy : Int, day : Int) -> String {
  let texts : Array[String] = if intimacy < 100 {
    [
      "カウンターは8席。テーブルが2つ。こぢんまりした店だ。",
      "壁に「日替わり定食 一種類のみ」と書いてある。潔い。",
      "向こうの席の人、いつも同じ時間に来る。常連なのかも。",
      "丸山さんの包丁さばきは見事だ。三十年の腕前。",
    ]
  } else if intimacy < 300 {
    [
      "ひよりはいつも文庫本を持っている。ジャンルはバラバラみたいだ。",
      "ひよりは漬物が苦手らしい。小鉢だけ残している。",
      "店の壁の写真。若い丸山と、もう一人は……奥さんだろうか。",
      "ひよりは食べるのがゆっくりだ。丁寧に味わっている感じ。",
    ]
  } else if intimacy < 600 {
    [
      "ひよりの好きなメニューは親子丼。卵がふわふわのやつ。",
      "ひよりは大学で文学を勉強しているらしい。丸山から聞いた。",
      "カウンターの端に、ひよりが座る場所が決まっている。窓際。",
      "ひよりは食後にお茶を飲みながら本を読む。それが日課らしい。",
    ]
  } else {
    [
      "ひよりは笑うとき、少しだけ目を細める。",
      "ひよりの読む速度が落ちている気がする。……こっちを気にしてる？",
      "丸山が「あの二人分」と言って仕込みをしていた。",
      "ひよりのカバンに、前に勧めた本が入っているのが見えた。",
    ]
  }
  texts[day % texts.length()]
}

/// 「丸山と話す」で得られる会話メモ
///
/// アルバムの「会話メモ」に蓄積される。丸山からの情報。
pub fn get_talk_text(intimacy : Int, day : Int) -> String {
  let texts : Array[String] = if intimacy < 100 {
    [
      "この店は30年前に開業した。最初はもっと広かったらしい。",
      "丸山さんは毎朝4時に起きて仕込みをしている。",
      "日替わりが一種類なのは「迷わせたくない」からだそうだ。",
      "丸山さんの口癖は「まあ食べてみなよ」。",
    ]
  } else if intimacy < 300 {
    [
      "あの子（ひより）は半年前から来ている。最初は緊張していた。",
      "ひよりは最初、カレーしか頼まなかった。今は日替わりを食べている。",
      "丸山さんの奥さんは5年前に亡くなった。壁の写真の人だ。",
      "ひよりは漬物だけは残す。無理に勧めないのが丸山流。",
    ]
  } else if intimacy < 600 {
    [
      "ひよりは近くの大学に通っている。文学部らしい。",
      "丸山さん曰く「あの子、最近よく笑うようになった」。",
      "ひよりの好きなメニューは親子丼と煮込みハンバーグ。",
      "丸山さんは奥さんのレシピを大事にしている。親子丼がそれ。",
    ]
  } else {
    [
      "丸山 「あんたが来ない日、あの子ちょっとソワソワしてたよ」",
      "丸山 「俺の店で出会って仲良くなるなんて、嬉しいもんだね」",
      "丸山 「来年もこの店やってるから、いつでも来なよ」",
      "丸山 「あの子の笑顔、あんたのおかげだよ。俺にはわかる」",
    ]
  }
  texts[day % texts.length()]
}
